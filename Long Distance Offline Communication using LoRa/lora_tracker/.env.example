# LoRa GPS Tracker – Environment Configuration
# Copy to .env and edit, or export these before running server.py

# Receiver GPS coordinates (where the base station is located)
RECEIVER_LAT=17.3850
RECEIVER_LNG=78.4867

# Serial port (leave blank for auto-detection)
# SERIAL_PORT=/dev/ttyUSB0

# Serial baud rate
SERIAL_BAUD=9600

# Rolling history buffer size
MAX_HISTORY=500

# OSRM routing server – use local Docker for fully offline routing:
#   docker run -t -v "${PWD}:/data" ghcr.io/project-osrm/osrm-backend \
#     osrm-routed --algorithm mld /data/map.osrm
OSRM_HOST=http://router.project-osrm.org
OSRM_TIMEOUT=5
